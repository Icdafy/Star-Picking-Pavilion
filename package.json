{
  "name": "star-picking-pavilion",
  "productName": "摘星阁",
  "version": "0.0.1",
  "description": "摘星阁（Star-Picking-Pavilion）· 低空经济与商业航天热点情报站（聚合信源 + AI 精选，本地运行）",
  "author": "摘星阁",
  "license": "MIT",
  "homepage": "https://github.com/Icdafy/Star-Picking-Pavilion",
  "repository": {
    "type": "git",
    "url": "https://github.com/Icdafy/Star-Picking-Pavilion.git"
  },
  "main": "electron/main.js",
  "scripts": {
    "test": "node --test test/*.test.js",
    "start": "electron .",
    "server": "node server/index.js",
    "pipeline": "node scripts/run-pipeline.js",
    "icon": "python build/make-icon.py",
    "dist": "electron-builder --win --publish never",
    "release": "electron-builder --win --publish always"
  },
  "dependencies": {
    "cheerio": "^1.0.0",
    "electron-updater": "^6.8.9",
    "iconv-lite": "^0.6.3",
    "node-cron": "^3.0.3",
    "rss-parser": "^3.13.0"
  },
  "devDependencies": {
    "electron": "^42.4.0",
    "electron-builder": "^26.15.2"
  },
  "build": {
    "appId": "com.icdafy.star-picking-pavilion",
    "productName": "摘星阁",
    "executableName": "Star-Picking-Pavilion",
    "copyright": "Copyright © 2026 摘星阁",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "**/*",
      "!**/*.md",
      "!data/**",
      "!dist/**",
      "!.github/**",
      "!.claude/**",
      "!scripts/**",
      "!**/.gitignore",
      "!**/*.map"
    ],
    "asarUnpack": [
      "renderer/**",
      "config/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "build/icon.ico",
      "artifactName": "Star-Picking-Pavilion-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "摘星阁",
      "uninstallDisplayName": "摘星阁",
      "guid": "5fea1cfe-e72e-5af6-9770-01a551e1f773",
      "deleteAppDataOnUninstall": false,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Icdafy",
        "repo": "Star-Picking-Pavilion"
      }
    ]
  }
}
